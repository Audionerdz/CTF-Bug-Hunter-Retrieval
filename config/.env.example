# ========================================
# CTF Bug Hunter Retrieval - Configuration
# ========================================
# Copy this file to .env and fill in your actual API keys
# NEVER commit .env to Git!

# TELEGRAM (from @BotFather on Telegram)
# Get your token: https://core.telegram.org/bots/tutorial
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# PINECONE (from pinecone.io)
# Free tier available at: https://www.pinecone.io/
PINECONE_API_KEY=YOUR_PINECONE_API_KEY_HERE

# OPENAI (from openai.com)
# Free $5 credits available: https://platform.openai.com/account/billing/overview
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# SYSTEM PATHS (Advanced users only - normally auto-detected)
# Uncomment and modify only if you've changed default installation paths
# RAG_PATH=/home/kali/Desktop/RAG
# VENV_PATH=/root/.openskills/venv
